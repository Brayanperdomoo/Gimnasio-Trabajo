        "type": "object",
        "required": [
          "plan_id",
          "nombre",
          "email",
          "telefono",
          "fecha_inscripcion",
          "estado"
        ],
        "properties": {
          "plan_id": {
            "type": "integer",
            "example": 1
          },
          "nombre": {
            "type": "string",
            "example": "Carlos Ramírez"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "carlos@example.com"
          },
          "telefono": {
            "type": "string",
            "example": "3107654321"
          },
          "fecha_inscripcion": {
            "type": "string",
            "format": "date",
            "example": "2026-04-28"
          },
          "estado": {
            "type": "string",
            "example": "activo",
            "enum": [
              "activo",
              "inactivo",
              "suspendido"
            ]
          }
        }
      },
      "Miembro": {
        "allOf": [
