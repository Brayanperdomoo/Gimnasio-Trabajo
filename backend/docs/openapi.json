      "name": "Miembros",
      "description": "Operaciones CRUD de miembros"
    },
    {
      "name": "Clases",
      "description": "Operaciones CRUD de clases"
    },
    {
      "name": "Reservas",
      "description": "Operaciones CRUD de reservas"
    }
  ],
