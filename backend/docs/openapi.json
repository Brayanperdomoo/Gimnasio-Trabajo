  "components": {
    "schemas": {
      "EntrenadorInput": {
        "type": "object",
        "required": [
          "nombre",
          "especialidad",
          "email",
          "telefono",
          "activo"
        ],
        "properties": {
          "nombre": {
            "type": "string",
            "example": "Laura Méndez"
          },
          "especialidad": {
            "type": "string",
            "example": "Funcional"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "laura@gimnasio.com"
          },
          "telefono": {
            "type": "string",
            "example": "3001234567"
          },
          "activo": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Entrenador": {
        "allOf": [
          {
            "$ref": "#/components/schemas/EntrenadorInput"
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              },
              "created_at": {
                "type": "string",
                "example": "2026-04-28 04:45:41"
              },
              "updated_at": {
                "type": "string",
                "example": "2026-04-28 04:45:41"
              }
            }
          }
        ]
      },
      "PlanInput": {
        "type": "object",
        "required": [
          "nombre",
          "descripcion",
          "precio_mensual",
          "duracion_dias",
          "activo"
        ],
        "properties": {
          "nombre": {
            "type": "string",
            "example": "Plan Premium"
          },
          "descripcion": {
            "type": "string",
            "example": "Acceso completo al gimnasio y clases grupales"
          },
          "precio_mensual": {
            "type": "number",
            "format": "float",
            "example": 120000
          },
          "duracion_dias": {
            "type": "integer",
            "example": 30
          },
          "activo": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Plan": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PlanInput"
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              },
